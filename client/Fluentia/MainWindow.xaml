<Window x:Class="Fluentia.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Fluentia"
        Width="480" Height="720"
        MinWidth="400" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgDarkBrush}"
        ResizeMode="CanResize">

    <!-- TrayIcon created in code-behind for reliable shell registration -->

    <Grid>
        <!-- Main panel background -->
        <Border Background="{StaticResource BgPanelBrush}" CornerRadius="0" Margin="0">
            <Grid Margin="24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Title -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
                    <TextBlock Text="🎙" FontSize="28" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <StackPanel>
                        <TextBlock Text="Fluentia" FontSize="22" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock Text="Voice Input Relay" FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>
                </StackPanel>

                <!-- Server URL -->
                <StackPanel Grid.Row="1" Margin="0,0,0,16">
                    <TextBlock Text="Server URL" FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                    <TextBox x:Name="ServerUrlBox" Text="ws://localhost:8080/ws"
                             Style="{StaticResource DarkTextBox}"/>
                </StackPanel>

                <!-- Connect Button -->
                <Button Grid.Row="2" x:Name="ConnectBtn" Content="Connect &amp; Create Room"
                        Style="{StaticResource AccentButton}" Click="Connect_Click" Margin="0,0,0,16"/>

                <!-- QR Code -->
                <Border Grid.Row="3" Background="{StaticResource BgInputBrush}"
                        CornerRadius="16" Padding="16" Margin="0,0,0,16"
                        HorizontalAlignment="Center">
                    <StackPanel HorizontalAlignment="Center">
                        <Image x:Name="QrCodeImage" Width="300" Height="300"
                               RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                        <TextBlock x:Name="QrHintText" Text="Connect to generate QR code"
                                   FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Status -->
                <Border Grid.Row="4" Background="{StaticResource BgInputBrush}"
                        CornerRadius="10" Padding="12,10" Margin="0,0,0,12">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse x:Name="StatusDot" Width="8" Height="8" Margin="0,0,10,0">
                            <Ellipse.Fill>
                                <SolidColorBrush Color="{StaticResource Danger}"/>
                            </Ellipse.Fill>
                        </Ellipse>
                        <TextBlock x:Name="StatusText" Text="Not connected"
                                   FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>
                </Border>

                <!-- Refresh Button -->
                <Button Grid.Row="5" Content="Refresh Room" Style="{StaticResource SecondaryButton}"
                        Click="Refresh_Click" Margin="0,0,0,12"/>

                <!-- Log area -->
                <Border Grid.Row="6" Background="{StaticResource BgInputBrush}" CornerRadius="10" Padding="8">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <TextBlock x:Name="LogText" FontSize="11" FontFamily="Consolas"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   TextWrapping="Wrap"/>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
