<Window x:Class="Fluentia.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Fluentia"
        Width="560" Height="760"
        MinWidth="500" MinHeight="640"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResizeWithGrip">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0" ResizeBorderThickness="7" GlassFrameThickness="0" CornerRadius="0"/>
    </shell:WindowChrome.WindowChrome>

    <Border CornerRadius="24"
            Background="{DynamicResource BgDarkBrush}"
            BorderBrush="{DynamicResource DividerBrush}"
            BorderThickness="1"
            Effect="{DynamicResource CardShadow}">
        <Grid ClipToBounds="True">
            <Grid.RowDefinitions>
                <RowDefinition Height="52"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="Transparent"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"
                    MouseLeftButtonUp="TitleBar_MouseLeftButtonUp">
                <Grid Margin="18,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border x:Name="BtnClose" Width="14" Height="14" CornerRadius="7"
                                Background="#FF5F57" Margin="0,0,8,0" Cursor="Hand"
                                MouseLeftButtonDown="TrafficClose_Click"
                                ToolTip="Hide to notification area">
                            <Path x:Name="CloseX"
                                  Data="M4,4 L10,10 M10,4 L4,10"
                                  Stroke="#4D0000"
                                  StrokeThickness="1.2"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  Visibility="Collapsed"/>
                        </Border>
                        <Border x:Name="BtnMinimize" Width="14" Height="14" CornerRadius="7"
                                Background="#FEBC2E" Margin="0,0,8,0" Cursor="Hand"
                                MouseLeftButtonDown="TrafficMinimize_Click"
                                ToolTip="Minimize">
                            <Path x:Name="MinLine"
                                  Data="M3,7 L11,7"
                                  Stroke="#995700"
                                  StrokeThickness="1.2"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  Visibility="Collapsed"/>
                        </Border>
                        <Border x:Name="BtnMaximize" Width="14" Height="14" CornerRadius="7"
                                Background="#28C840" Cursor="Hand"
                                MouseLeftButtonDown="TrafficMaximize_Click"
                                ToolTip="Maximize or restore">
                            <Path x:Name="MaxDiamond"
                                  Data="M3,7 L7,3 L11,7 L7,11 Z"
                                  Stroke="#006500"
                                  StrokeThickness="1"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  Visibility="Collapsed"/>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock x:Name="TitleLabel"
                                   Text="Fluentia"
                                   FontSize="14"
                                   FontFamily="Segoe UI Variable Display"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   HorizontalAlignment="Center"
                                   MouseLeftButtonDown="Title_DevTap"/>
                        <TextBlock x:Name="TitleSubtitleText"
                                   Text="Windows relay"
                                   FontSize="11"
                                   Foreground="{DynamicResource TextTertiaryBrush}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>

                    <Button Grid.Column="2"
                            x:Name="SettingsTitleButton"
                            Style="{StaticResource IconButton}"
                            Click="Settings_Click"
                            ToolTip="Open settings">
                        <TextBlock FontFamily="Segoe Fluent Icons"
                                   Text="&#xE713;"
                                   FontSize="18"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"/>
                    </Button>
                </Grid>
            </Border>

            <Grid Grid.Row="1" ClipToBounds="True">
                <Border x:Name="SettingsScrim"
                        Visibility="Collapsed"
                        Opacity="0"
                        Background="{DynamicResource OverlayBrush}"
                        MouseLeftButtonDown="SettingsScrim_MouseLeftButtonDown"/>

                <Grid x:Name="MainContentHost">
                    <Grid.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform x:Name="MainContentScaleTransform" ScaleX="1" ScaleY="1"/>
                            <TranslateTransform x:Name="MainContentTranslateTransform" X="0"/>
                        </TransformGroup>
                    </Grid.RenderTransform>

                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Margin="24,10,24,24">
                            <Border Background="{DynamicResource BgPanelBrush}"
                                    BorderBrush="{DynamicResource DividerBrush}"
                                    BorderThickness="1"
                                    CornerRadius="24"
                                    Padding="22"
                                    Margin="0,0,0,18">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock x:Name="HeroTitleText"
                                                   Text="Secure desktop pairing"
                                                   FontSize="24"
                                                   FontFamily="Segoe UI Variable Display"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <TextBlock x:Name="ConnectionHintText"
                                                   Text="Connect to your relay server to prepare a reusable session."
                                                   FontSize="13"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   Margin="0,8,0,0"
                                                   TextWrapping="Wrap"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,18,0,0" VerticalAlignment="Center">
                                            <Ellipse x:Name="StatusDot" Width="10" Height="10" Margin="0,0,10,0">
                                                <Ellipse.Fill>
                                                    <SolidColorBrush Color="{StaticResource Danger}"/>
                                                </Ellipse.Fill>
                                            </Ellipse>
                                            <TextBlock x:Name="StatusText"
                                                       Text="Not connected"
                                                       FontSize="13"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <Button Grid.Column="1"
                                            x:Name="NewSessionBtn"
                                            Content="New Session"
                                            Style="{StaticResource SecondaryButton}"
                                            Click="Refresh_Click"
                                            Padding="16,10"
                                            Margin="18,0,0,0"
                                            VerticalAlignment="Top"/>
                                </Grid>
                            </Border>

                            <Border Background="{DynamicResource BgPanelBrush}"
                                    BorderBrush="{DynamicResource DividerBrush}"
                                    BorderThickness="1"
                                    CornerRadius="22"
                                    Padding="22"
                                    Margin="0,0,0,18">
                                <StackPanel>
                                    <TextBlock x:Name="ConnectionSectionTitleText"
                                               Text="Connection"
                                               FontSize="18"
                                               FontFamily="Segoe UI Variable Display"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <TextBlock x:Name="ServerUrlLabelText"
                                               Text="Server URL"
                                               FontSize="12"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               Margin="0,14,0,8"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="12"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0"
                                                 x:Name="ServerUrlBox"
                                                 Text="wss://f.106918.xyz/ws"
                                                 Style="{StaticResource DarkTextBox}"/>
                                        <Button Grid.Column="2"
                                                x:Name="ConnectBtn"
                                                Content="Connect"
                                                Style="{StaticResource AccentButton}"
                                                Click="Connect_Click"
                                                MinWidth="108"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Background="{DynamicResource BgPanelBrush}"
                                    BorderBrush="{DynamicResource DividerBrush}"
                                    BorderThickness="1"
                                    CornerRadius="22"
                                    Padding="22"
                                    Margin="0,0,0,18">
                                <StackPanel>
                                    <Grid Margin="0,0,0,14">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock x:Name="PairingSectionTitleText"
                                                       Text="Pairing"
                                                       FontSize="18"
                                                       FontFamily="Segoe UI Variable Display"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                                            <TextBlock x:Name="PairingSectionSubtitleText"
                                                       Text="Scan the QR code or enter the short code on your phone."
                                                       FontSize="12"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       Margin="0,4,0,0"/>
                                        </StackPanel>
                                        <Button Grid.Column="1"
                                                x:Name="QrExpandBtn"
                                                Content="Show QR Code"
                                                Style="{StaticResource SecondaryButton}"
                                                Visibility="Collapsed"
                                                Click="QrExpand_Click"
                                                Padding="14,10"/>
                                    </Grid>

                                    <Border x:Name="PairingNoticeCard"
                                            Background="{DynamicResource BgInputBrush}"
                                            BorderBrush="{DynamicResource DividerBrush}"
                                            BorderThickness="1"
                                            CornerRadius="18"
                                            Padding="18"
                                            Margin="0,0,0,14"
                                            Visibility="Collapsed">
                                        <StackPanel>
                                            <TextBlock x:Name="PairingNoticeTitle"
                                                       Text="Ready"
                                                       FontSize="15"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                                            <TextBlock x:Name="PairingNoticeText"
                                                       Text=""
                                                       FontSize="12"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       Margin="0,6,0,0"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>

                                    <Border x:Name="DeviceCodePanel"
                                            Background="{DynamicResource AccentSoftBrush}"
                                            BorderBrush="{DynamicResource DividerBrush}"
                                            BorderThickness="1"
                                            CornerRadius="18"
                                            Padding="18"
                                            Margin="0,0,0,14"
                                            Visibility="Collapsed"
                                            Cursor="Hand"
                                            MouseLeftButtonDown="DeviceCode_Click"
                                            ToolTip="Copy device code">
                                        <StackPanel>
                                            <TextBlock x:Name="DeviceCodeTitleText"
                                                       Text="Connection Code"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                                            <TextBlock x:Name="DeviceCodeText"
                                                       Margin="0,10,0,0"
                                                       FontSize="30"
                                                       FontFamily="Consolas"
                                                       FontWeight="Bold"
                                                       Foreground="{DynamicResource AccentBrush}"
                                                       TextAlignment="Center"/>
                                            <TextBlock x:Name="DeviceCodeHintText"
                                                       Text="Visible only while no phone is connected"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       TextAlignment="Center"
                                                       Margin="0,8,0,0"/>
                                        </StackPanel>
                                    </Border>

                                    <Border x:Name="QrContainer"
                                            Background="{DynamicResource BgInputBrush}"
                                            BorderBrush="{DynamicResource DividerBrush}"
                                            BorderThickness="1"
                                            CornerRadius="22"
                                            Padding="18"
                                            HorizontalAlignment="Stretch"
                                            Visibility="Collapsed">
                                        <StackPanel HorizontalAlignment="Center">
                                            <Image x:Name="QrCodeImage"
                                                   Width="320"
                                                   Height="320"
                                                   RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                                            <TextBlock x:Name="QrTimerText"
                                                       Text=""
                                                       FontSize="12"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       Margin="0,12,0,0"
                                                       HorizontalAlignment="Center"/>
                                            <TextBlock x:Name="QrHintText"
                                                       Text=""
                                                       FontSize="11"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       TextAlignment="Center"
                                                       Margin="0,6,0,0"
                                                       HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <Border x:Name="LogContainer"
                                    Visibility="Collapsed"
                                    Background="{DynamicResource BgPanelBrush}"
                                    BorderBrush="{DynamicResource DividerBrush}"
                                    BorderThickness="1"
                                    CornerRadius="18"
                                    Padding="16">
                                <StackPanel>
                                    <TextBlock x:Name="DiagnosticsTitleText"
                                               Text="Diagnostics"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,10,0,0">
                                        <TextBlock x:Name="LogText"
                                                   FontSize="11"
                                                   FontFamily="Consolas"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   TextWrapping="Wrap"/>
                                    </ScrollViewer>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>

                <Border x:Name="SettingsPanel"
                        Width="340"
                        HorizontalAlignment="Right"
                        Background="{DynamicResource BgPanelBrush}"
                        BorderBrush="{DynamicResource DividerBrush}"
                        BorderThickness="1,0,0,0"
                        Visibility="Collapsed">
                    <Border.RenderTransform>
                        <TranslateTransform x:Name="SettingsPanelTranslateTransform" X="360"/>
                    </Border.RenderTransform>

                    <Grid Margin="26,24,26,24">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock x:Name="SettingsHeaderText"
                                       Text="Settings"
                                           FontSize="22"
                                           FontFamily="Segoe UI Variable Display"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock x:Name="SettingsSubheaderText"
                                       Text="Desktop behavior and file handling"
                                           FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           Margin="0,6,0,0"/>
                            </StackPanel>
                                <Button Grid.Column="1"
                                    x:Name="CloseSettingsButton"
                                    Style="{StaticResource IconButton}"
                                    Click="CloseSettings_Click"
                                    ToolTip="Close settings">
                                <TextBlock FontFamily="Segoe Fluent Icons"
                                           Text="&#xE711;"
                                           FontSize="16"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center"/>
                            </Button>
                        </Grid>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,22,0,18">
                            <StackPanel>
                                <Border Background="{DynamicResource BgInputBrush}"
                                        BorderBrush="{DynamicResource DividerBrush}"
                                        BorderThickness="1"
                                        CornerRadius="18"
                                        Padding="18"
                                        Margin="0,0,0,14">
                                    <StackPanel>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock x:Name="CloseBehaviorTitleText"
                                                           Text="Close button behavior"
                                                           FontSize="14"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                <TextBlock x:Name="CloseBehaviorBodyText"
                                                           Text="When enabled, closing the window hides Fluentia to the notification area."
                                                           FontSize="12"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           Margin="0,6,0,0"
                                                           TextWrapping="Wrap"/>
                                            </StackPanel>
                                            <CheckBox x:Name="CloseToTrayToggle"
                                                      Grid.Column="1"
                                                      Style="{StaticResource SwitchCheckBoxStyle}"
                                                      VerticalAlignment="Top"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <Border Background="{DynamicResource BgInputBrush}"
                                        BorderBrush="{DynamicResource DividerBrush}"
                                        BorderThickness="1"
                                        CornerRadius="18"
                                        Padding="18"
                                        Margin="0,0,0,14">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock x:Name="StartupTitleText"
                                                       Text="Launch at Windows startup"
                                                       FontSize="14"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                                            <TextBlock x:Name="StartupBodyText"
                                                       Text="Start Fluentia automatically after you sign in to Windows."
                                                       FontSize="12"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       Margin="0,6,0,0"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <CheckBox x:Name="LaunchAtStartupToggle"
                                                  Grid.Column="1"
                                                  Style="{StaticResource SwitchCheckBoxStyle}"
                                                  VerticalAlignment="Top"/>
                                    </Grid>
                                </Border>

                                <Border Background="{DynamicResource BgInputBrush}"
                                        BorderBrush="{DynamicResource DividerBrush}"
                                        BorderThickness="1"
                                        CornerRadius="18"
                                        Padding="18">
                                    <StackPanel>
                                        <TextBlock x:Name="ReceivedFilesTitleText"
                                                   Text="Received files"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <TextBlock x:Name="ReceivedFilesBodyText"
                                                   Text="Choose where incoming files are written on this PC."
                                                   FontSize="12"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   Margin="0,6,0,0"
                                                   TextWrapping="Wrap"/>
                                        <TextBox x:Name="SavePathBox"
                                                 Margin="0,14,0,0"
                                                 Style="{StaticResource DarkTextBox}"/>
                                        <Button x:Name="BrowseSavePathButton"
                                            Content="Browse"
                                                Margin="0,12,0,0"
                                                Style="{StaticResource SecondaryButton}"
                                                Click="BrowseSavePath_Click"
                                                HorizontalAlignment="Left"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>

                        <Button Grid.Row="2"
                            x:Name="SaveSettingsButton"
                            Content="Save Settings"
                                Style="{StaticResource AccentButton}"
                                Click="SaveSettings_Click"/>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
