<Window x:Class="Fluentia.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Fluentia"
        Width="560" Height="760"
        MinWidth="500" MinHeight="640"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResizeWithGrip">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0" ResizeBorderThickness="7" GlassFrameThickness="0" CornerRadius="0"/>
    </shell:WindowChrome.WindowChrome>

    <Border CornerRadius="24"
            Background="{DynamicResource BgDarkBrush}"
            BorderBrush="{DynamicResource DividerBrush}"
            BorderThickness="1"
            Effect="{DynamicResource CardShadow}">
        <Grid ClipToBounds="True">
            <Grid.RowDefinitions>
                <RowDefinition Height="48"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="Transparent"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"
                    MouseLeftButtonUp="TitleBar_MouseLeftButtonUp">
                <Grid Margin="18,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="BtnClose"
                                Width="18"
                                Height="18"
                                Margin="0,0,8,0"
                                Background="#FF5F57"
                                Style="{StaticResource TrafficLightButton}"
                                Click="TrafficClose_Click"
                                ToolTip="Hide to notification area">
                            <Path x:Name="CloseX"
                                  Data="M4,4 L10,10 M10,4 L4,10"
                                  Stroke="#4D0000"
                                  StrokeThickness="1.2"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  Visibility="Collapsed"/>
                        </Button>
                        <Button x:Name="BtnMinimize"
                                Width="18"
                                Height="18"
                                Margin="0,0,8,0"
                                Background="#FEBC2E"
                                Style="{StaticResource TrafficLightButton}"
                                Click="TrafficMinimize_Click"
                                ToolTip="Minimize">
                            <Path x:Name="MinLine"
                                  Data="M3,7 L11,7"
                                  Stroke="#995700"
                                  StrokeThickness="1.2"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  Visibility="Collapsed"/>
                        </Button>
                        <Button x:Name="BtnMaximize"
                                Width="18"
                                Height="18"
                                Background="#28C840"
                                Style="{StaticResource TrafficLightButton}"
                                Click="TrafficMaximize_Click"
                                ToolTip="Maximize or restore">
                            <Path x:Name="MaxDiamond"
                                  Data="M3,7 L7,3 L11,7 L7,11 Z"
                                  Stroke="#006500"
                                  StrokeThickness="1"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  Visibility="Collapsed"/>
                        </Button>
                    </StackPanel>

                    <StackPanel Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock x:Name="TitleLabel"
                                   Text="Fluentia"
                                   FontSize="15"
                                   FontFamily="Segoe UI Variable Display"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   HorizontalAlignment="Center"
                                   MouseLeftButtonDown="Title_DevTap"/>
                        <TextBlock x:Name="TitleSubtitleText"
                                   Text="Windows relay"
                                   Visibility="Collapsed"
                                   FontSize="11"
                                   Foreground="{DynamicResource TextTertiaryBrush}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>

                    <Button Grid.Column="2"
                            x:Name="SettingsTitleButton"
                            Style="{StaticResource IconButton}"
                            Click="Settings_Click"
                            ToolTip="Open settings">
                        <TextBlock FontFamily="Segoe Fluent Icons"
                                   Text="&#xE713;"
                                   FontSize="18"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"/>
                    </Button>
                </Grid>
            </Border>

            <Grid Grid.Row="1" ClipToBounds="True">
                <Border x:Name="SettingsScrim"
                    Panel.ZIndex="1"
                        Visibility="Collapsed"
                        Opacity="0"
                        Background="{DynamicResource OverlayBrush}"
                        MouseLeftButtonDown="SettingsScrim_MouseLeftButtonDown"/>

                <Grid x:Name="MainContentHost">
                    <Grid.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform x:Name="MainContentScaleTransform" ScaleX="1" ScaleY="1"/>
                            <TranslateTransform x:Name="MainContentTranslateTransform" X="0"/>
                        </TransformGroup>
                    </Grid.RenderTransform>

                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Margin="24,10,24,24">
                            <Border Background="{DynamicResource BgPanelBrush}"
                                    BorderBrush="{DynamicResource DividerBrush}"
                                    BorderThickness="1"
                                    CornerRadius="24"
                                    Padding="22"
                                    Margin="0,0,0,18">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock x:Name="HeroTitleText"
                                                   Text="Secure desktop pairing"
                                                   FontSize="24"
                                                   FontFamily="Segoe UI Variable Display"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <TextBlock x:Name="ConnectionHintText"
                                                   Text="Connect to your relay server to prepare a reusable session."
                                                   FontSize="13"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   Margin="0,8,0,0"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>

                                    <Border x:Name="StatusBadge"
                                            Grid.Column="1"
                                            Background="{DynamicResource BgInputBrush}"
                                            BorderBrush="{DynamicResource DividerBrush}"
                                            BorderThickness="1"
                                            CornerRadius="14"
                                            Padding="12,8"
                                            Margin="18,0,0,0"
                                            VerticalAlignment="Top">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <Rectangle x:Name="StatusIndicator"
                                                       Width="8"
                                                       Height="8"
                                                       RadiusX="2"
                                                       RadiusY="2"
                                                       Margin="0,0,8,0"
                                                       Fill="{DynamicResource DangerBrush}"/>
                                            <TextBlock x:Name="StatusText"
                                                       Text="Not connected"
                                                       FontSize="13"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Border>

                            <Border Background="{DynamicResource BgPanelBrush}"
                                    BorderBrush="{DynamicResource DividerBrush}"
                                    BorderThickness="1"
                                    CornerRadius="22"
                                    Padding="22"
                                    Margin="0,0,0,18">
                                <StackPanel>
                                    <TextBlock x:Name="ConnectionSectionTitleText"
                                               Text="Connection"
                                               FontSize="18"
                                               FontFamily="Segoe UI Variable Display"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <TextBlock x:Name="ServerUrlLabelText"
                                               Text="Server URL"
                                               FontSize="12"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               Margin="0,14,0,8"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="12"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0"
                                                 x:Name="ServerUrlBox"
                                                 Text="wss://f.106918.xyz/ws"
                                                 Style="{StaticResource DarkTextBox}"/>
                                        <Button Grid.Column="2"
                                                x:Name="ConnectBtn"
                                                Content="Connect"
                                                Style="{StaticResource AccentButton}"
                                                Click="Connect_Click"
                                                MinWidth="108"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Background="{DynamicResource BgPanelBrush}"
                                    BorderBrush="{DynamicResource DividerBrush}"
                                    BorderThickness="1"
                                    CornerRadius="22"
                                    Padding="22"
                                    Margin="0,0,0,18">
                                <StackPanel>
                                    <Grid Margin="0,0,0,14">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock x:Name="PairingSectionTitleText"
                                                       Text="Pairing"
                                                       FontSize="18"
                                                       FontFamily="Segoe UI Variable Display"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                                            <TextBlock x:Name="PairingSectionSubtitleText"
                                                       Text="Scan the QR code or enter the short code on your phone."
                                                       FontSize="12"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       Margin="0,4,0,0"/>
                                        </StackPanel>
                                            <Button Grid.Column="1"
                                                x:Name="SendFileButton"
                                                Content="Send Files to Phone"
                                                Style="{StaticResource SecondaryButton}"
                                                Visibility="Collapsed"
                                                Click="SendFile_Click"
                                                Padding="16,10"
                                                Margin="0,0,10,0"/>
                                            <Button Grid.Column="2"
                                                x:Name="QrExpandBtn"
                                                Content="Show QR Code"
                                                Style="{StaticResource SecondaryButton}"
                                                Visibility="Collapsed"
                                                Click="QrExpand_Click"
                                                Padding="14,10"/>
                                    </Grid>

                                    <Border x:Name="PairingNoticeCard"
                                            Background="{DynamicResource BgInputBrush}"
                                            BorderBrush="{DynamicResource DividerBrush}"
                                            BorderThickness="1"
                                            CornerRadius="18"
                                            Padding="18"
                                            Margin="0,0,0,14"
                                            Visibility="Collapsed">
                                        <StackPanel>
                                            <TextBlock x:Name="PairingNoticeTitle"
                                                       Text="Ready"
                                                       FontSize="15"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                                            <TextBlock x:Name="PairingNoticeText"
                                                       Text=""
                                                       FontSize="12"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       Margin="0,6,0,0"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>

                                    <Border x:Name="DeviceCodePanel"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Padding="0"
                                            Margin="0,0,0,18"
                                            Visibility="Collapsed"
                                            Cursor="Hand"
                                            MouseLeftButtonDown="DeviceCode_Click"
                                            ToolTip="Copy device code">
                                        <StackPanel HorizontalAlignment="Center">
                                            <TextBlock x:Name="DeviceCodeTitleText"
                                                       Text="Connection Code"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       TextAlignment="Center"/>
                                            <Border Background="{DynamicResource BgInputBrush}"
                                                    BorderBrush="{DynamicResource DividerBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="22"
                                                    Padding="24,14"
                                                    Margin="0,10,0,0">
                                                <TextBlock x:Name="DeviceCodeText"
                                                           FontSize="34"
                                                           FontFamily="Consolas"
                                                           FontWeight="Bold"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                                           TextAlignment="Center"/>
                                            </Border>
                                            <TextBlock x:Name="DeviceCodeHintText"
                                                       Text="Visible only while no phone is connected"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       TextAlignment="Center"
                                                       Margin="0,10,0,0"/>
                                        </StackPanel>
                                    </Border>

                                    <Border x:Name="QrContainer"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Padding="0"
                                            HorizontalAlignment="Stretch"
                                            Visibility="Collapsed"
                                            Cursor="Hand"
                                            MouseLeftButtonDown="QrContainer_MouseLeftButtonDown">
                                        <StackPanel HorizontalAlignment="Center">
                                            <Border Background="#FFFFFFFF"
                                                    CornerRadius="30"
                                                    Padding="16">
                                                <Image x:Name="QrCodeImage"
                                                       Width="420"
                                                       Height="420"
                                                       RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                                            </Border>
                                            <TextBlock x:Name="QrTimerText"
                                                       Text=""
                                                       FontSize="12"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       Margin="0,14,0,0"
                                                       HorizontalAlignment="Center"/>
                                            <TextBlock x:Name="QrHintText"
                                                       Text=""
                                                       FontSize="11"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       TextAlignment="Center"
                                                       Margin="0,8,0,0"
                                                       HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>

                                    <Border x:Name="TransferProgressCard"
                                            Visibility="Collapsed"
                                            Background="#FFFBFCFF"
                                            BorderBrush="#1B7085C6"
                                            BorderThickness="1"
                                            CornerRadius="24"
                                            Padding="18,16,18,14"
                                            Margin="0,16,0,0"
                                            MouseEnter="TransferProgressCard_MouseEnter"
                                            MouseLeave="TransferProgressCard_MouseLeave">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="24"
                                                              ShadowDepth="0"
                                                              Color="#24000000"
                                                              Opacity="0.9"/>
                                        </Border.Effect>
                                        <Border.RenderTransform>
                                            <TranslateTransform x:Name="TransferProgressCardTransform" Y="0"/>
                                        </Border.RenderTransform>
                                        <StackPanel>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock x:Name="TransferProgressTitleText"
                                                               Text="Uploading 0 files"
                                                               FontSize="19"
                                                               FontWeight="SemiBold"
                                                               Foreground="#FF161924"/>
                                                    <TextBlock x:Name="TransferProgressSubtitleText"
                                                               Text="0% · Preparing"
                                                               Margin="0,6,0,0"
                                                               FontSize="12"
                                                               Foreground="#FF69708F"/>
                                                </StackPanel>

                                                <StackPanel x:Name="TransferProgressActions"
                                                            Grid.Column="1"
                                                            Orientation="Horizontal"
                                                            VerticalAlignment="Top"
                                                            Opacity="0">
                                                    <StackPanel.RenderTransform>
                                                        <TranslateTransform x:Name="TransferProgressActionsTransform" X="8"/>
                                                    </StackPanel.RenderTransform>

                                                    <Button x:Name="TransferPauseButton"
                                                            Width="30"
                                                            Height="30"
                                                            Margin="0,0,6,0"
                                                            Click="TransferPause_Click"
                                                            Background="#145C4EC8"
                                                            BorderThickness="0"
                                                            Foreground="#FF5242BE"
                                                            Cursor="Hand"
                                                            ToolTip="Pause transfer">
                                                        <TextBlock x:Name="TransferPauseGlyph"
                                                                   Text="⏸"
                                                                   FontSize="13"
                                                                   VerticalAlignment="Center"
                                                                   HorizontalAlignment="Center"/>
                                                    </Button>

                                                    <Button x:Name="TransferCancelButton"
                                                            Width="30"
                                                            Height="30"
                                                            Margin="0,0,6,0"
                                                            Click="TransferCancel_Click"
                                                            Background="#145C4EC8"
                                                            BorderThickness="0"
                                                            Foreground="#FF5242BE"
                                                            Cursor="Hand"
                                                            ToolTip="Cancel transfer">
                                                        <TextBlock Text="✕"
                                                                   FontSize="13"
                                                                   VerticalAlignment="Center"
                                                                   HorizontalAlignment="Center"/>
                                                    </Button>

                                                    <Button x:Name="TransferExpandButton"
                                                            Width="30"
                                                            Height="30"
                                                            Click="TransferExpand_Click"
                                                            Background="#145C4EC8"
                                                            BorderThickness="0"
                                                            Foreground="#FF5242BE"
                                                            Cursor="Hand"
                                                            ToolTip="Expand details">
                                                        <TextBlock x:Name="TransferExpandGlyph"
                                                                   Text="⤢"
                                                                   FontSize="13"
                                                                   VerticalAlignment="Center"
                                                                   HorizontalAlignment="Center"/>
                                                    </Button>

                                                    <Border x:Name="TransferSuccessBadge"
                                                            Width="30"
                                                            Height="30"
                                                            Margin="6,0,0,0"
                                                            Background="#1C31C96B"
                                                            CornerRadius="15"
                                                            Visibility="Collapsed">
                                                        <Border.RenderTransform>
                                                            <ScaleTransform x:Name="TransferSuccessBadgeScaleTransform"
                                                                            ScaleX="1"
                                                                            ScaleY="1"/>
                                                        </Border.RenderTransform>
                                                        <Border.RenderTransformOrigin>
                                                            0.5,0.5
                                                        </Border.RenderTransformOrigin>
                                                        <TextBlock Text="✓"
                                                                   FontSize="14"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="#FF169A53"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"/>
                                                    </Border>
                                                </StackPanel>
                                            </Grid>

                                                <Grid Height="12"
                                                  Margin="0,16,0,0">
                                                <Border Background="#1E6B55E7"
                                                    Height="3"
                                                    VerticalAlignment="Center"
                                                    CornerRadius="2"/>
                                                <Border x:Name="TransferProgressLine"
                                                    Background="#FF6B55E7"
                                                    Height="3"
                                                    VerticalAlignment="Center"
                                                        CornerRadius="2"
                                                        RenderTransformOrigin="0,0.5">
                                                    <Border.RenderTransform>
                                                        <ScaleTransform x:Name="TransferProgressScaleTransform"
                                                                        ScaleX="0"/>
                                                    </Border.RenderTransform>
                                                </Border>
                                                <Path x:Name="TransferProgressSlackLine"
                                                      Visibility="Collapsed"
                                                      Stroke="#FF6B55E7"
                                                      StrokeThickness="2"
                                                      Stretch="Fill"
                                                      Height="10"
                                                      VerticalAlignment="Center"
                                                      Opacity="0"
                                                      Data="M 0,3 C 26,10 52,10 78,3 S 130,-4 156,3 S 208,10 234,3"/>
                                            </Grid>

                                            <StackPanel x:Name="TransferProgressDetailsPanel"
                                                        Visibility="Collapsed"
                                                        Margin="0,14,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <Border x:Name="LogContainer"
                                    Visibility="Collapsed"
                                    Background="{DynamicResource BgPanelBrush}"
                                    BorderBrush="{DynamicResource DividerBrush}"
                                    BorderThickness="1"
                                    CornerRadius="18"
                                    Padding="16">
                                <StackPanel>
                                    <TextBlock x:Name="DiagnosticsTitleText"
                                               Text="Diagnostics"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,10,0,0">
                                        <TextBlock x:Name="LogText"
                                                   FontSize="11"
                                                   FontFamily="Consolas"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   TextWrapping="Wrap"/>
                                    </ScrollViewer>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>

                <Border x:Name="SettingsPanel"
                    Panel.ZIndex="2"
                        Width="340"
                        HorizontalAlignment="Right"
                        Background="{DynamicResource BgPanelBrush}"
                        BorderBrush="{DynamicResource DividerBrush}"
                        BorderThickness="1,0,0,0"
                        Visibility="Collapsed">
                    <Border.RenderTransform>
                        <TranslateTransform x:Name="SettingsPanelTranslateTransform" X="360"/>
                    </Border.RenderTransform>

                    <Grid Margin="26,24,26,24">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock x:Name="SettingsHeaderText"
                                       Text="Settings"
                                           FontSize="22"
                                           FontFamily="Segoe UI Variable Display"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock x:Name="SettingsSubheaderText"
                                       Text="Desktop behavior and file handling"
                                           FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           Margin="0,6,0,0"/>
                            </StackPanel>
                                <Button Grid.Column="1"
                                    x:Name="CloseSettingsButton"
                                    Style="{StaticResource IconButton}"
                                    Click="CloseSettings_Click"
                                    ToolTip="Close settings">
                                <TextBlock FontFamily="Segoe Fluent Icons"
                                           Text="&#xE711;"
                                           FontSize="16"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center"/>
                            </Button>
                        </Grid>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,22,0,18">
                            <StackPanel>
                                <Border Background="{DynamicResource BgInputBrush}"
                                        BorderBrush="{DynamicResource DividerBrush}"
                                        BorderThickness="1"
                                        CornerRadius="18"
                                        Padding="18"
                                        Margin="0,0,0,14">
                                    <StackPanel>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock x:Name="CloseBehaviorTitleText"
                                                           Text="Close button behavior"
                                                           FontSize="14"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                <TextBlock x:Name="CloseBehaviorBodyText"
                                                           Text="When enabled, closing the window hides Fluentia to the notification area."
                                                           FontSize="12"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           Margin="0,6,0,0"
                                                           TextWrapping="Wrap"/>
                                            </StackPanel>
                                            <CheckBox x:Name="CloseToTrayToggle"
                                                      Grid.Column="1"
                                                      Style="{StaticResource SwitchCheckBoxStyle}"
                                                      VerticalAlignment="Top"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <Border Background="{DynamicResource BgInputBrush}"
                                        BorderBrush="{DynamicResource DividerBrush}"
                                        BorderThickness="1"
                                        CornerRadius="18"
                                        Padding="18"
                                        Margin="0,0,0,14">
                                    <StackPanel>
                                        <TextBlock x:Name="LanguageTitleText"
                                                   Text="App language"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <TextBlock x:Name="LanguageBodyText"
                                                   Text="Choose the display language for the desktop client."
                                                   FontSize="12"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   Margin="0,6,0,0"
                                                   TextWrapping="Wrap"/>
                                        <ComboBox x:Name="LanguageSelector"
                                                  Margin="0,14,0,0"
                                                  Style="{StaticResource DarkComboBox}"
                                                  SelectionChanged="LanguageSelector_SelectionChanged">
                                            <ComboBoxItem x:Name="LanguageSystemOption" Tag="system"/>
                                            <ComboBoxItem x:Name="LanguageEnglishOption" Tag="en"/>
                                            <ComboBoxItem x:Name="LanguageChineseOption" Tag="zh-CN"/>
                                        </ComboBox>
                                    </StackPanel>
                                </Border>

                                <Border Background="{DynamicResource BgInputBrush}"
                                        BorderBrush="{DynamicResource DividerBrush}"
                                        BorderThickness="1"
                                        CornerRadius="18"
                                        Padding="18"
                                        Margin="0,0,0,14">
                                    <StackPanel>
                                        <TextBlock x:Name="SessionTitleText"
                                                   Text="Pairing session"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <TextBlock x:Name="SessionBodyText"
                                                   Text="Create a fresh pairing session only when you need to rotate the current trusted secret."
                                                   FontSize="12"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   Margin="0,6,0,0"
                                                   TextWrapping="Wrap"/>
                                        <Button x:Name="NewSessionSettingsButton"
                                                Content="Create New Pairing Session"
                                                Margin="0,14,0,0"
                                                HorizontalAlignment="Left"
                                                Style="{StaticResource SecondaryButton}"
                                                Click="Refresh_Click"/>
                                    </StackPanel>
                                </Border>

                                <Border Background="{DynamicResource BgInputBrush}"
                                        BorderBrush="{DynamicResource DividerBrush}"
                                        BorderThickness="1"
                                        CornerRadius="18"
                                        Padding="18"
                                        Margin="0,0,0,14">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock x:Name="StartupTitleText"
                                                       Text="Launch at Windows startup"
                                                       FontSize="14"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                                            <TextBlock x:Name="StartupBodyText"
                                                       Text="Start Fluentia automatically after you sign in to Windows."
                                                       FontSize="12"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       Margin="0,6,0,0"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <CheckBox x:Name="LaunchAtStartupToggle"
                                                  Grid.Column="1"
                                                  Style="{StaticResource SwitchCheckBoxStyle}"
                                                  VerticalAlignment="Top"/>
                                    </Grid>
                                </Border>

                                <Border Background="{DynamicResource BgInputBrush}"
                                        BorderBrush="{DynamicResource DividerBrush}"
                                        BorderThickness="1"
                                        CornerRadius="18"
                                        Padding="18"
                                        Margin="0,0,0,14">
                                    <StackPanel>
                                        <TextBlock x:Name="UpdateTitleText"
                                                   Text="App updates"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <TextBlock x:Name="UpdateBodyText"
                                                   Text="Fluentia checks for updates automatically on startup. You can also check manually."
                                                   FontSize="12"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   Margin="0,6,0,0"
                                                   TextWrapping="Wrap"/>
                                        <TextBlock x:Name="UpdateStatusText"
                                                   FontSize="12"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   Margin="0,8,0,0"
                                                   TextWrapping="Wrap"
                                                   Visibility="Collapsed"/>
                                        <Button x:Name="CheckUpdateButton"
                                                Content="Check for Updates"
                                                Margin="0,14,0,0"
                                                HorizontalAlignment="Left"
                                                Style="{StaticResource SecondaryButton}"
                                                Click="CheckUpdate_Click"/>
                                    </StackPanel>
                                </Border>

                                <Border Background="{DynamicResource BgInputBrush}"
                                        BorderBrush="{DynamicResource DividerBrush}"
                                        BorderThickness="1"
                                        CornerRadius="18"
                                        Padding="18">
                                    <StackPanel>
                                        <TextBlock x:Name="ReceivedFilesTitleText"
                                                   Text="Received files"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <TextBlock x:Name="ReceivedFilesBodyText"
                                                   Text="Choose where incoming files are written on this PC."
                                                   FontSize="12"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   Margin="0,6,0,0"
                                                   TextWrapping="Wrap"/>
                                        <TextBox x:Name="SavePathBox"
                                                 Margin="0,14,0,0"
                                                 Style="{StaticResource DarkTextBox}"/>
                                        <Button x:Name="BrowseSavePathButton"
                                            Content="Browse"
                                                Margin="0,12,0,0"
                                                Style="{StaticResource SecondaryButton}"
                                                Click="BrowseSavePath_Click"
                                                HorizontalAlignment="Left"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>

                        <Button Grid.Row="2"
                            x:Name="SaveSettingsButton"
                            Content="Save Settings"
                                Style="{StaticResource AccentButton}"
                                Click="SaveSettings_Click"/>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
