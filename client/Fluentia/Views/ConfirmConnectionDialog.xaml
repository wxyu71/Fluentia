<Window x:Class="Fluentia.Views.ConfirmConnectionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Fluentia — Connection Request"
        Width="400" SizeToContent="Height"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Window.Resources>
        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="10" Padding="0,0,0,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.82"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.65"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

        <Border CornerRadius="20" Background="{DynamicResource BgPanelBrush}"
            BorderBrush="{DynamicResource DividerBrush}" BorderThickness="1"
            Effect="{DynamicResource CardShadow}">
        <StackPanel Margin="28,24,28,24">

            <!-- Header row -->
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Shield icon (drawn in code-behind) -->
                <Ellipse Width="40" Height="40" Fill="{DynamicResource AccentBrush}" VerticalAlignment="Top"/>
                <TextBlock Grid.Column="0" Text="🔒" FontSize="20"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Width="40" TextAlignment="Center"/>

                <StackPanel Grid.Column="1" Margin="14,0,0,0">
                    <TextBlock Text="Connection Request"
                               FontSize="17" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock Text="A device wants to pair with your PC"
                               FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="0,3,0,0"/>
                </StackPanel>
            </Grid>

            <!-- Verification ID (prominent) -->
            <Border Background="{DynamicResource BgInputBrush}" CornerRadius="14" Padding="16,14" Margin="0,0,0,14">
                <StackPanel>
                    <TextBlock Text="VERIFICATION ID" FontSize="11" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                    <TextBlock x:Name="VerifyIdText" Text=""
                               FontSize="28" FontWeight="Bold" FontFamily="Consolas"
                               Foreground="{DynamicResource AccentBrush}" TextAlignment="Center"/>
                    <TextBlock Text="Must match the code on your phone"
                               FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                               TextAlignment="Center" Margin="0,6,0,0"/>
                </StackPanel>
            </Border>

            <!-- Device info (secondary) -->
            <Border Background="{DynamicResource BgInputBrush}" CornerRadius="14" Padding="14,10" Margin="0,0,0,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Device" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Top" Width="56"/>
                    <TextBlock x:Name="UserAgentText" Grid.Column="1" Text=""
                               FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}"
                               TextWrapping="Wrap"/>
                </Grid>
            </Border>

            <!-- Buttons -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="RejectBtn" Grid.Column="0" Content="Reject"
                    Background="{DynamicResource BgInputBrush}" Foreground="{DynamicResource DangerBrush}"
                        Style="{StaticResource ActionBtn}"
                        Click="Reject_Click"/>

                <Button x:Name="ApproveBtn" Grid.Column="2" Content="Approve"
                    Background="{DynamicResource AccentBrush}" Foreground="White"
                        Style="{StaticResource ActionBtn}"
                        Click="Approve_Click"/>
            </Grid>
        </StackPanel>
    </Border>
</Window>
